# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Security
JWT_SECRET_KEY=your_super_secret_jwt_key_generate_one_with_openssl
ALGORITHM=HS256

# Databases
# Pour PostgreSQL, utilisez asyncpg pour la gestion asynchrone
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/orientation_db
CHROMA_PERSIST_PATH=./chroma_db

# RAG & AI Configuration
BGE_MODEL_NAME=BAAI/bge-m3
LLM_PROVIDER=gemini # options: gemini, openai, mistral

# App Settings
DEBUG=True
