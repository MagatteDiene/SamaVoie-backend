# ============================================================
# SamaVoie Backend — Variables d'environnement
# Copier ce fichier vers .env et remplir les valeurs réelles
# JAMAIS committer .env dans git
# ============================================================

# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here       # Optionnel — seulement si LLM_PROVIDER=openai
MISTRAL_API_KEY=your_mistral_api_key_here     # Optionnel — seulement si LLM_PROVIDER=mistral

# --- Sécurité ---
# Générer avec : openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_key_here

# --- Bases de données ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/orientation_db
CHROMA_PERSIST_PATH=./chroma_db

# --- RAG & IA ---
BGE_MODEL_NAME=BAAI/bge-m3
LLM_PROVIDER=gemini                          # gemini | openai | mistral | llama
RAG_TOP_K=5

# --- CORS (virgule-séparés, sans espaces) ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- App ---
DEBUG=True                                   # False en production
